# Alexandria Cover Designer — Environment Variables
# Copy this file to .env and fill in your values

# === AI Image Generation ===
# Primary: Replicate (FLUX.1 schnell)
REPLICATE_API_TOKEN=your_replicate_token_here

# Alternative: fal.ai
FAL_KEY=your_fal_key_here

# Alternative: Google (Imagen 3)
GOOGLE_API_KEY=your_google_api_key_here

# === Generation Settings ===
AI_PROVIDER=replicate          # replicate | fal | google | local
AI_MODEL=flux-schnell          # flux-schnell | flux-dev | sdxl | imagen3
VARIANTS_PER_COVER=5           # Number of design variants per cover
IMAGE_SIZE=1024                # Generated image size (will be resized for compositing)
BATCH_CONCURRENCY=3            # Parallel generation requests

# === Paths ===
INPUT_DIR=Input Covers
OUTPUT_DIR=Output Covers
SAMPLE_DIR=Sample Output style covers

# === Google Drive (for output sync) ===
GDRIVE_OUTPUT_FOLDER_ID=1Vr184ZsX3k38xpmZkd8g2vwB5y9LYMRC
GDRIVE_INPUT_FOLDER_ID=1ybFYDJk7Y3VlbsEjRAh1LOfdyVsHM_cS

# === Quality Gate ===
MIN_QUALITY_SCORE=0.6          # Minimum score to keep a generated image (0-1)
MAX_RETRIES=2                  # Re-generate if below quality threshold

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=text                # text | json
